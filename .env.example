# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://scout:scout@localhost:5432/scout

# AI Provider: mock, azure, ollama
AI_PROVIDER=mock
MOCK_AI_MODE=clean

# Azure AI Foundry (if AI_PROVIDER=azure)
AZURE_ENDPOINT=https://your-resource.openai.azure.com
AZURE_API_KEY=your-api-key
AZURE_TEXT_DEPLOYMENT=gpt-4o
AZURE_VISION_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2024-02-01

# Ollama (if AI_PROVIDER=ollama)
OLLAMA_HOST=localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5:14b
OLLAMA_VISION_MODEL=gemma3:12b

# Playwright
PLAYWRIGHT_TESTS_DIR=/mnt/h/ETS/SCOUT/poc/tests
PLAYWRIGHT_PROJECT_ROOT=/mnt/h/ETS/SCOUT/poc
SCOUT_SCRIPT_TIMEOUT=180000
SCOUT_MOCK=0

# Auth
DASHBOARD_AUTH=True
