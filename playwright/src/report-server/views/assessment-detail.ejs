<%- include('header', { title: assessment.name, active: 'assessments' }) %>

<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <a href="/assessments" class="hover:underline">Assessments</a> → <span class="text-gray-900"><%= assessment.name %></span>
  </nav>
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= assessment.name %></h1>
      <p class="text-sm text-gray-500 mt-1"><%= assessment.description %></p>
      <% if (assessment.env_name) { %>
      <p class="text-xs text-gray-400 mt-1">Environment: <a href="/environments" class="text-scout-600 hover:underline"><%= assessment.env_name %></a> · <span class="font-mono"><%= assessment.env_url %></span></p>
      <% } %>
    </div>
    <button onclick="document.getElementById('info-modal').classList.remove('hidden')" class="inline-flex items-center gap-1.5 rounded-lg bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 border border-gray-300 shadow-sm">
      ℹ️ Details
    </button>
  </div>
</div>

<!-- Info modal -->
<div id="info-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
  <div class="bg-white rounded-xl shadow-xl max-w-lg w-full mx-4 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Assessment Details</h2>
      <button onclick="document.getElementById('info-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
    </div>
    <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div>
        <dt class="text-xs font-medium text-gray-500 uppercase">Subject</dt>
        <dd class="mt-0.5 text-gray-900"><%= assessment.subject %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-gray-500 uppercase">Grade</dt>
        <dd class="mt-0.5 text-gray-900"><%= assessment.grade %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-gray-500 uppercase">Year</dt>
        <dd class="mt-0.5 text-gray-900"><%= assessment.year %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-gray-500 uppercase">Items</dt>
        <dd class="mt-0.5 text-gray-900"><%= assessment.itemCount || 'TBD' %></dd>
      </div>
      <div class="col-span-2">
        <dt class="text-xs font-medium text-gray-500 uppercase">Environment</dt>
        <dd class="mt-0.5 text-gray-900"><%= assessment.env_name || '—' %></dd>
      </div>
      <div class="col-span-2">
        <dt class="text-xs font-medium text-gray-500 uppercase">Form Value</dt>
        <dd class="mt-0.5 text-gray-900 font-mono text-xs"><%= assessment.form_value || '—' %></dd>
      </div>
      <% if (assessment.description) { %>
      <div class="col-span-2">
        <dt class="text-xs font-medium text-gray-500 uppercase">Description</dt>
        <dd class="mt-0.5 text-gray-900"><%= assessment.description %></dd>
      </div>
      <% } %>
    </dl>
    <div class="mt-5 flex justify-end">
      <button onclick="document.getElementById('info-modal').classList.add('hidden')" class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200">Close</button>
    </div>
  </div>
</div>

<!-- Test Scripts -->
<div class="flex items-center justify-between mb-3">
  <h2 class="text-lg font-semibold text-gray-900">Test Scripts</h2>
  <div class="flex items-center gap-2">
    <button onclick="runAllScripts()" id="run-all-btn" class="inline-flex items-center rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-700 shadow-sm">
      ▶ Run All Scripts
    </button>
    <button onclick="document.getElementById('new-tc-modal').classList.remove('hidden')" class="inline-flex items-center rounded-lg bg-scout-600 px-4 py-2 text-sm font-medium text-white hover:bg-scout-700 shadow-sm">
      New Test Script
    </button>
  </div>
</div>

<!-- New Test Script modal -->
<div id="new-tc-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
  <div class="bg-white rounded-xl shadow-xl max-w-md w-full mx-4 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">New Test Script</h2>
      <button onclick="document.getElementById('new-tc-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
    </div>
    <p class="text-sm text-gray-500 mb-4">Create a new test script for <strong><%= assessment.name %></strong>.</p>
    <form id="new-tc-form">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Test Type <span class="text-red-500">*</span></label>
        <select id="new-tc-type" required class="w-full rounded-md border-gray-300 text-sm px-3 py-2 border focus:ring-scout-500 focus:border-scout-500">
          <option value="">Choose a type…</option>
          <option value="visual">Visual Regression</option>
          <option value="content">Content Validation</option>
          <option value="feature">Feature</option>
        </select>
      </div>
      <div id="new-tc-baseline-section" class="mb-4 hidden">
        <label class="block text-sm font-medium text-gray-700 mb-1">Compare Against Version</label>
        <select id="new-tc-baseline" class="w-full rounded-md border-gray-300 text-sm px-3 py-2 border focus:ring-scout-500 focus:border-scout-500">
          <option value="">Latest approved baseline (default)</option>
          <option value="v2025">v2025</option>
          <option value="v2024">v2024</option>
          <option value="v2023">v2023</option>
        </select>
        <p class="text-xs text-gray-400 mt-1">Leave as default to compare against the most recent approved baseline.</p>
      </div>
      <div class="flex justify-end gap-2">
        <button type="button" onclick="document.getElementById('new-tc-modal').classList.add('hidden')" class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200">Cancel</button>
        <button type="submit" class="rounded-lg bg-scout-600 px-4 py-2 text-sm font-medium text-white hover:bg-scout-700">Continue</button>
      </div>
    </form>
  </div>
</div>

<script>
document.getElementById('new-tc-type').addEventListener('change', function() {
  var section = document.getElementById('new-tc-baseline-section');
  if (this.value === 'visual') { section.classList.remove('hidden'); } else { section.classList.add('hidden'); }
});
document.getElementById('new-tc-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var type = document.getElementById('new-tc-type').value;
  if (!type) return;
  var url = '/builder?assessment=<%= assessment.id %>&type=' + encodeURIComponent(type);
  var baseline = document.getElementById('new-tc-baseline').value;
  if (type === 'visual' && baseline) url += '&baseline=' + encodeURIComponent(baseline);
  window.location.href = url;
});
</script>
<div class="bg-white rounded-lg shadow overflow-hidden">
  <!-- Toolbar -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
    <div class="flex items-center gap-2 text-sm text-gray-600">
      <span>Show</span>
      <select id="page-size" class="rounded border-gray-300 text-sm py-1 px-2 focus:ring-scout-500 focus:border-scout-500">
        <option value="10">10</option>
        <option value="25" selected>25</option>
        <option value="50">50</option>
        <option value="100">100</option>
        <option value="500">500</option>
      </select>
      <span>entries</span>
    </div>
    <div class="flex items-center gap-2">
      <input type="text" id="tc-search" placeholder="Search test scripts…"
        class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm focus:border-scout-500 focus:ring-1 focus:ring-scout-500 w-56">
      <button id="tc-filter-btn" class="rounded-lg bg-scout-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-scout-700">Filter</button>
    </div>
  </div>

  <% if (testCases.length > 0) { %>
  <table class="min-w-full divide-y divide-gray-200" id="tc-table">
    <thead class="bg-gray-50">
      <tr>
        <th class="sortable px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase cursor-pointer hover:text-gray-700 select-none" data-col="name">
          Test Script <span class="sort-arrow ml-1 text-gray-700">▲</span>
        </th>
        <th class="sortable px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase cursor-pointer hover:text-gray-700 select-none" data-col="file">
          File <span class="sort-arrow ml-1 text-gray-300">▲</span>
        </th>
        <th class="sortable px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase cursor-pointer hover:text-gray-700 select-none" data-col="tests">
          Tests <span class="sort-arrow ml-1 text-gray-300">▲</span>
        </th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase select-none w-16">Edit</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200" id="tc-body">
      <% testCases.forEach(function(tc) { %>
      <tr class="hover:bg-gray-50 cursor-pointer tc-row"
          data-name="<%= tc.name %>"
          data-file="<%= tc.relativePath %>"
          data-tests="<%= tc.testCount %>"
          data-href="/builder?file=<%= encodeURIComponent(tc.relativePath) %>">
        <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= tc.name %></td>
        <td class="px-4 py-3 text-xs font-mono text-gray-500"><%= tc.relativePath %></td>
        <td class="px-4 py-3 text-sm text-gray-500 text-center"><%= tc.testCount %></td>
        <td class="px-4 py-3 text-center">
          <a href="/builder?file=<%= encodeURIComponent(tc.relativePath) %>" onclick="event.stopPropagation()"
             class="inline-flex items-center rounded-md bg-scout-50 px-2 py-1 text-xs text-scout-700 hover:bg-scout-100 border border-scout-200" title="Edit with AI">
            ✏️
          </a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } else { %>
  <div class="px-6 py-8 text-center text-gray-500">
    No test scripts cover this assessment yet.
  </div>
  <% } %>

  <!-- Pagination -->
  <div class="flex items-center justify-end px-4 py-3 border-t border-gray-200 bg-gray-50 text-sm text-gray-600">
    <div class="flex items-center gap-3">
      <span id="tc-page-info">Showing 1–<%= testCases.length %> of <%= testCases.length %></span>
      <div class="flex gap-1">
        <button id="tc-prev" class="rounded border border-gray-300 px-3 py-1 hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed" disabled>Previous</button>
        <button id="tc-next" class="rounded border border-gray-300 px-3 py-1 hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed" disabled>Next</button>
      </div>
    </div>
  </div>
</div>


<script>
(function() {
  var allRows = Array.from(document.querySelectorAll('.tc-row'));
  var filtered = allRows.slice();
  var pageSize = 25;
  var currentPage = 1;
  var sortCol = 'name';
  var sortAsc = true;

  // Row click
  allRows.forEach(function(r) { r.addEventListener('click', function() { window.location.href = r.dataset.href; }); });

  // Search
  var searchInput = document.getElementById('tc-search');
  document.getElementById('tc-filter-btn').addEventListener('click', applyFilter);
  searchInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') applyFilter(); });
  function applyFilter() {
    var q = searchInput.value.toLowerCase().trim();
    filtered = allRows.filter(function(r) { return !q || r.textContent.toLowerCase().indexOf(q) !== -1; });
    currentPage = 1;
    doSort();
    render();
  }

  // Page size
  document.getElementById('page-size').addEventListener('change', function() { pageSize = parseInt(this.value); currentPage = 1; render(); });

  // Sort
  document.querySelectorAll('.sortable').forEach(function(th) {
    th.addEventListener('click', function() {
      var col = th.dataset.col;
      if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
      document.querySelectorAll('.sort-arrow').forEach(function(a) { a.textContent = '▲'; a.classList.add('text-gray-300'); a.classList.remove('text-gray-700'); });
      var arrow = th.querySelector('.sort-arrow');
      arrow.textContent = sortAsc ? '▲' : '▼';
      arrow.classList.remove('text-gray-300'); arrow.classList.add('text-gray-700');
      doSort();
      render();
    });
  });

  function doSort() {
    filtered.sort(function(a, b) {
      var av = (a.dataset[sortCol] || '').toLowerCase();
      var bv = (b.dataset[sortCol] || '').toLowerCase();
      if (sortCol === 'tests') { av = parseInt(av) || 0; bv = parseInt(bv) || 0; return sortAsc ? av - bv : bv - av; }
      if (av < bv) return sortAsc ? -1 : 1;
      if (av > bv) return sortAsc ? 1 : -1;
      return 0;
    });
  }

  // Pagination
  document.getElementById('tc-prev').addEventListener('click', function() { currentPage--; render(); });
  document.getElementById('tc-next').addEventListener('click', function() { currentPage++; render(); });

  function render() {
    var total = filtered.length;
    var pages = Math.max(1, Math.ceil(total / pageSize));
    var start = (currentPage - 1) * pageSize;
    var end = Math.min(start + pageSize, total);
    allRows.forEach(function(r) { r.style.display = 'none'; });
    var tbody = document.getElementById('tc-body');
    filtered.forEach(function(r) { tbody.appendChild(r); });
    for (var i = start; i < end; i++) { filtered[i].style.display = ''; }
    document.getElementById('tc-page-info').textContent = total > 0 ? 'Showing ' + (start + 1) + '–' + end + ' of ' + total : 'No results';
    document.getElementById('tc-prev').disabled = currentPage <= 1;
    document.getElementById('tc-next').disabled = currentPage >= pages;
  }

  render();
})();

function runAllScripts() {
  var btn = document.getElementById('run-all-btn');
  btn.disabled = true;
  btn.textContent = 'Creating run...';

  // First create an ad-hoc suite, then run it
  var assessmentId = '<%= assessment.id %>';
  var assessmentName = '<%= assessment.name %>';

  fetch('/suites', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name: 'Ad-hoc: ' + assessmentName,
      description: 'Auto-created from assessment page run',
      scripts: [], // Will use all assessment scripts
      browser_profiles: ['chrome-desktop']
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.error) { alert(data.error); return; }
    // Run the suite
    return fetch('/suites/' + data.id + '/run', { method: 'POST' })
      .then(function(r) { return r.json(); })
      .then(function(runData) {
        if (runData.error) { alert(runData.error); return; }
        btn.textContent = 'Redirecting...';
        setTimeout(function() { window.location.href = '/runs/' + runData.runId; }, 2000);
      });
  })
  .catch(function(e) { alert('Error: ' + e.message); })
  .finally(function() { btn.disabled = false; btn.textContent = '▶ Run All Scripts'; });
}
</script>

<%- include('footer') %>
