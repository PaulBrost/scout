<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.title ? title + ' — ' : '' %>SCOUT Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { colors: {
        scout: { 50:'#f0f9ff', 100:'#e0f2fe', 500:'#0ea5e9', 600:'#0284c7', 700:'#0369a1', 800:'#075985', 900:'#0c4a6e' }
      }}}
    }
  </script>
  <style>
    #sidebar { width: 16rem; transition: width 0.2s ease; }
    #sidebar.collapsed { width: 4rem; }
    #sidebar.collapsed .nav-label { display: none; }
    #sidebar.collapsed nav { padding-left: 0.5rem; padding-right: 0.5rem; }
    #sidebar.collapsed nav a { justify-content: center; padding-left: 0; padding-right: 0; }
    #main-wrap.sidebar-expanded { margin-left: 16rem; }
    #main-wrap.sidebar-collapsed { margin-left: 4rem; }
    #main-wrap { transition: margin-left 0.2s ease; }
    #toggle-icon-open, #toggle-icon-close { transition: opacity 0.15s; }
  </style>
</head>
<body class="h-full">
<% if (!locals.hideNav) { %>
<!-- Full-width top header -->
<header class="fixed inset-x-0 top-0 z-40 h-14 bg-[#1e293b] flex items-center justify-between px-5">
  <div class="flex items-center gap-2">
    <!-- Sidebar toggle -->
    <button id="sidebar-toggle" title="Toggle sidebar" class="text-gray-400 hover:text-white p-1.5 rounded-lg hover:bg-white/10 transition-colors">
      <svg id="toggle-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <a href="/" class="flex items-center gap-3">
      <img src="/img/scout-logo-transparent.png" alt="SCOUT" class="h-8 w-auto">
      <div class="leading-tight">
        <span class="text-white font-bold text-lg tracking-wide">SCOUT</span>
        <span class="text-gray-400 text-[10px] ml-1.5 hidden sm:inline"> - Every pixel, every word, every time</span>
      </div>
    </a>
  </div>
  <div class="flex items-center gap-3">
    <span class="text-sm text-gray-300"><%= locals.username || 'scout' %></span>
    <a href="/logout" title="Sign out" class="text-gray-400 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
    </a>
  </div>
</header>
<!-- Sidebar -->
<aside id="sidebar" class="fixed top-14 bottom-0 left-0 z-30 bg-[#1e293b] border-t border-white/10 flex flex-col overflow-hidden">
  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    <a href="/" title="Dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'dashboard' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">📊</span><span class="nav-label">Dashboard</span>
    </a>
    <a href="/assessments" title="Assessments" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'assessments' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">📚</span><span class="nav-label">Assessments</span>
    </a>
    <a href="/items" title="Items" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'items' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">📝</span><span class="nav-label">Items</span>
    </a>
    <a href="/test-cases" title="Test Scripts" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'test-cases' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">🧪</span><span class="nav-label">Test Scripts</span>
    </a>
    <a href="/suites" title="Test Suites" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'suites' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">📦</span><span class="nav-label">Test Suites</span>
    </a>

    <a href="/runs" title="Test Results" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'runs' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">▶️</span><span class="nav-label">Test Results</span>
    </a>
    <a href="/reviews" title="Review Queue" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'reviews' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">✅</span><span class="nav-label">Review Queue</span>
    </a>
    <div class="border-t border-white/10 my-2"></div>
    <a href="/environments" title="Environments" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'environments' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">🌐</span><span class="nav-label">Environments</span>
    </a>
    <div class="border-t border-white/10 my-2"></div>
    <a href="/admin/ai" title="AI Configuration" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm <%= locals.active === 'admin-ai' ? 'bg-blue-600 text-white font-medium' : 'text-gray-300 hover:bg-white/10' %>">
      <span class="text-base flex-shrink-0">⚙️</span><span class="nav-label">AI Settings</span>
    </a>
  </nav>
</aside>
<script>
(function() {
  var sb = document.getElementById('sidebar');
  var btn = document.getElementById('sidebar-toggle');
  var collapsed = localStorage.getItem('scout_sidebar') === 'collapsed';
  function apply() {
    var mw = document.getElementById('main-wrap');
    if (collapsed) {
      sb.classList.add('collapsed');
      mw.classList.remove('sidebar-expanded');
      mw.classList.add('sidebar-collapsed');
    } else {
      sb.classList.remove('collapsed');
      mw.classList.remove('sidebar-collapsed');
      mw.classList.add('sidebar-expanded');
    }
  }
  if (collapsed) sb.classList.add('collapsed');
  btn.addEventListener('click', function() {
    collapsed = !collapsed;
    localStorage.setItem('scout_sidebar', collapsed ? 'collapsed' : 'expanded');
    apply();
  });
  document.addEventListener('DOMContentLoaded', apply);
})();
</script>
<% } %>
<div class="min-h-screen flex <%= !locals.hideNav ? 'pt-14' : '' %>">
<div id="main-wrap" class="flex-1 flex flex-col <%= !locals.hideNav ? 'sidebar-expanded' : '' %>">
  <main class="flex-1 p-6">
