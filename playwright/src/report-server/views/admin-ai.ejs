<%- include('header', { title: 'AI Configuration', active: 'admin-ai' }) %>

<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold text-gray-900">AI Configuration</h1>
  <%- include('partials/help-modal', {
    helpTitle: 'AI Configuration Help',
    helpContent: '<p class="font-medium text-gray-900">Managing AI Settings</p>' +
      '<p>This page controls how the SCOUT AI assistant behaves when interacting with users in the test editor.</p>' +
      '<p><strong>System Prompt</strong> — The instructions given to the AI at the start of every conversation. Customize this to change the AI\'s personality, capabilities, and constraints.</p>' +
      '<p><strong>Tools</strong> — AI tools are actions the assistant can take during conversations (e.g., read files, update code, search tests). Toggle tools on/off to control what the AI can do.</p>' +
      '<p><strong>Provider</strong> — Shows which AI backend is active (Azure, Ollama, or Mock). Change the provider via environment variables.</p>'
  }) %>
</div>

<% if (locals.success) { %>
<div class="mb-4 rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-700">
  <%= success === 'prompt' ? 'System prompt saved successfully.' : 'Settings saved successfully.' %>
</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main column: System Prompt & Tools -->
  <div class="lg:col-span-2 space-y-6">

    <!-- System Prompt -->
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">System Prompt</h2>
        <p class="text-xs text-gray-500 mt-1">Instructions sent to the AI at the start of every conversation</p>
      </div>
      <form action="/admin/ai/prompt" method="POST" class="p-6">
        <textarea name="prompt" rows="14"
          class="w-full rounded-md border-gray-300 shadow-sm focus:border-scout-500 focus:ring-scout-500 text-sm font-mono leading-relaxed"
          spellcheck="false"><%= typeof settings.system_prompt === 'string' ? settings.system_prompt : JSON.stringify(settings.system_prompt || '', null, 2) %></textarea>
        <div class="flex justify-between items-center mt-3">
          <p class="text-xs text-gray-400">Changes take effect for new conversations immediately</p>
          <button type="submit" class="rounded-lg bg-scout-600 px-4 py-2 text-sm font-medium text-white hover:bg-scout-700">
            Save Prompt
          </button>
        </div>
      </form>
    </div>

    <!-- Tools -->
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">AI Tools</h2>
        <p class="text-xs text-gray-500 mt-1">Actions the AI can perform during conversations</p>
      </div>
      <div class="divide-y divide-gray-100">
        <% var categories = {}; tools.forEach(function(t) { if (!categories[t.category]) categories[t.category] = []; categories[t.category].push(t); }); %>
        <% Object.keys(categories).sort().forEach(function(cat) { %>
        <div class="px-6 py-3">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= cat %></h3>
          <div class="space-y-3">
            <% categories[cat].forEach(function(tool) { %>
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-900"><%= tool.name %></span>
                  <code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded text-gray-500"><%= tool.id %></code>
                </div>
                <p class="text-xs text-gray-500 mt-0.5 leading-relaxed"><%= tool.description %></p>
              </div>
              <button onclick="toggleTool('<%= tool.id %>', this)"
                class="relative inline-flex h-5 w-9 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-scout-500 focus:ring-offset-2 <%= tool.enabled ? 'bg-scout-600' : 'bg-gray-200' %>"
                data-enabled="<%= tool.enabled %>">
                <span class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out <%= tool.enabled ? 'translate-x-4' : 'translate-x-0' %>"></span>
              </button>
            </div>
            <% }); %>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- Sidebar: Provider Info & Settings -->
  <div class="space-y-6">

    <!-- Provider Info -->
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">AI Provider</h2>
      </div>
      <div class="p-6 space-y-3">
        <div>
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Active Provider</span>
          <div class="mt-1 flex items-center gap-2">
            <span class="inline-flex items-center rounded-full px-2.5 py-1 text-sm font-medium
              <%= provider === 'azure' ? 'bg-blue-100 text-blue-800' : provider === 'ollama' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
              <%= provider === 'azure' ? '☁️ Azure AI Foundry' : provider === 'ollama' ? '🦙 Ollama' : '🧪 Mock' %>
            </span>
          </div>
        </div>
        <% if (provider === 'azure') { %>
        <div>
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Text Model</span>
          <p class="mt-1 text-sm text-gray-700 font-mono"><%= process.env.AZURE_AI_TEXT_DEPLOYMENT || 'gpt-4o-mini' %></p>
        </div>
        <div>
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Vision Model</span>
          <p class="mt-1 text-sm text-gray-700 font-mono"><%= process.env.AZURE_AI_VISION_DEPLOYMENT || 'gpt-4o' %></p>
        </div>
        <div>
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Endpoint</span>
          <p class="mt-1 text-sm text-gray-700 font-mono break-all"><%= (process.env.AZURE_AI_ENDPOINT || '').substring(0, 60) %><%= (process.env.AZURE_AI_ENDPOINT || '').length > 60 ? '...' : '' %></p>
        </div>
        <% } else if (provider === 'ollama') { %>
        <div>
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Text Model</span>
          <p class="mt-1 text-sm text-gray-700 font-mono"><%= process.env.OLLAMA_TEXT_MODEL || 'qwen2.5:14b' %></p>
        </div>
        <div>
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Vision Model</span>
          <p class="mt-1 text-sm text-gray-700 font-mono"><%= process.env.OLLAMA_VISION_MODEL || 'gemma3:12b' %></p>
        </div>
        <div>
          <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">Host</span>
          <p class="mt-1 text-sm text-gray-700 font-mono"><%= process.env.OLLAMA_HOST || 'http://localhost:11434' %></p>
        </div>
        <% } %>
        <p class="text-xs text-gray-400 mt-2">Provider is configured via environment variables. Restart the server to change.</p>
      </div>
    </div>

    <!-- Chat Settings -->
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-gray-900">Chat Settings</h2>
      </div>
      <form action="/admin/ai/settings" method="POST" class="p-6 space-y-4">
        <div>
          <label class="text-sm font-medium text-gray-700">Max Conversation Turns</label>
          <input type="number" name="max_conversation_turns" value="<%= settings.max_conversation_turns || 50 %>" min="5" max="200"
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-scout-500 focus:ring-scout-500 text-sm">
          <p class="text-xs text-gray-400 mt-1">Older messages are trimmed when exceeded</p>
        </div>
        <div>
          <label class="text-sm font-medium text-gray-700">Tool Calling</label>
          <select name="tool_calling_enabled" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-scout-500 focus:ring-scout-500 text-sm">
            <option value="true" <%= settings.tool_calling_enabled !== false ? 'selected' : '' %>>Enabled</option>
            <option value="false" <%= settings.tool_calling_enabled === false ? 'selected' : '' %>>Disabled</option>
          </select>
          <p class="text-xs text-gray-400 mt-1">When disabled, AI can only respond with text</p>
        </div>
        <button type="submit" class="w-full rounded-lg bg-scout-600 px-4 py-2 text-sm font-medium text-white hover:bg-scout-700">
          Save Settings
        </button>
      </form>
    </div>
  </div>
</div>

<script>
async function toggleTool(toolId, btn) {
  try {
    var res = await fetch('/admin/ai/tools/' + toolId + '/toggle', { method: 'POST' });
    var data = await res.json();
    if (data.success) {
      var enabled = btn.dataset.enabled === 'true' ? false : true;
      btn.dataset.enabled = enabled;
      btn.className = btn.className
        .replace(enabled ? 'bg-gray-200' : 'bg-scout-600', enabled ? 'bg-scout-600' : 'bg-gray-200');
      var dot = btn.querySelector('span');
      dot.className = dot.className
        .replace(enabled ? 'translate-x-0' : 'translate-x-4', enabled ? 'translate-x-4' : 'translate-x-0');
    }
  } catch (err) {
    alert('Error toggling tool: ' + err.message);
  }
}
</script>

<%- include('footer') %>
